# =============================================================================
# CryptoQuant V3.0 - 环境变量配置示例
# =============================================================================
# 复制此文件为 .env.local 并填入实际的值
# 注意：.env.local 文件包含敏感信息，永远不要提交到 Git！
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase 配置
# -----------------------------------------------------------------------------
# Supabase 项目 URL（可在 Supabase Dashboard > Settings > API 找到）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（公开密钥，可以安全地暴露在前端代码中）
# 用于客户端连接，受 RLS 策略保护
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase 服务角色密钥（私有密钥，绝对不能暴露到前端！）
# 仅在服务端使用，可以绕过 RLS 策略
# 警告：如果泄露，攻击者可以访问所有用户数据！
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Stripe 配置（订阅支付管理）
# -----------------------------------------------------------------------------
# Stripe 可发布密钥（公开密钥，可以暴露在前端）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe 密钥（私有密钥，仅在服务端使用）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Webhook 签名密钥（用于验证 Webhook 请求）
# 在 Stripe Dashboard > Developers > Webhooks > 选择端点 > 查看签名密钥
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe 产品和价格 ID（在 Stripe Dashboard 创建产品后获取）
# Free 计划（默认免费，无需配置）
# STRIPE_PRICE_ID_FREE=

# Pro 计划（月付）
STRIPE_PRICE_ID_PRO_MONTHLY=price_your_pro_monthly_price_id

# Pro 计划（年付）
STRIPE_PRICE_ID_PRO_YEARLY=price_your_pro_yearly_price_id

# Ultra 计划（月付）
STRIPE_PRICE_ID_ULTRA_MONTHLY=price_your_ultra_monthly_price_id

# Ultra 计划（年付）
STRIPE_PRICE_ID_ULTRA_YEARLY=price_your_ultra_yearly_price_id

# -----------------------------------------------------------------------------
# 加密配置
# -----------------------------------------------------------------------------
# AES-256-GCM 加密密钥（用于加密交易所 API 密钥）
# 必须是 32 字符的随机字符串
# 生成方法：openssl rand -base64 32
ENCRYPTION_KEY=your_32_character_random_encryption_key_here

# -----------------------------------------------------------------------------
# Freqtrade 配置（量化交易引擎）
# -----------------------------------------------------------------------------
# Freqtrade API 地址（Docker 容器内部地址）
FREQTRADE_API_URL=http://localhost:8080

# Freqtrade API 认证信息
FREQTRADE_USERNAME=freqtrader
FREQTRADE_PASSWORD=your_freqtrade_password_here

# Freqtrade JWT 密钥（用于 WebSocket 认证）
FREQTRADE_WS_TOKEN=your_freqtrade_websocket_token

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
# 应用环境（development | production）
NEXT_PUBLIC_APP_ENV=development

# 应用 URL（用于重定向和回调）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 启用调试模式（development 环境自动启用）
NEXT_PUBLIC_DEBUG=true

# -----------------------------------------------------------------------------
# 监控和分析配置
# -----------------------------------------------------------------------------
# Vercel Analytics（已通过 @vercel/analytics 集成，无需配置）
# Sentry 错误追踪（可选）
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# -----------------------------------------------------------------------------
# 通知服务配置
# -----------------------------------------------------------------------------
# Telegram Bot（可选，用于推送交易通知）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# SMTP 邮件配置（可选，用于发送邮件通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@cryptoquant.com

# -----------------------------------------------------------------------------
# 第三方服务配置（可选）
# -----------------------------------------------------------------------------
# Upstash Redis（用于限流和缓存）
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# CCXT 默认配置（交易所集成）
CCXT_ENABLE_RATE_LIMIT=true
CCXT_TIMEOUT_MS=30000

# Cron Job 配置（定时任务安全验证）
CRON_SECRET=your_random_cron_secret_key_here

# -----------------------------------------------------------------------------
# 开发工具配置
# -----------------------------------------------------------------------------
# 启用 Next.js 重写（仅开发环境）
NEXT_PRIVATE_REWRITE_VALIDATION=false

# -----------------------------------------------------------------------------
# 高级配置（通常不需要修改）
# -----------------------------------------------------------------------------
# Supabase 存储桶（用于文件存储）
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=assets

# Session 配置
NEXT_PUBLIC_SESSION_COOKIE_NAME=sb-session-token
SESSION_MAX_AGE=604800

# API 限流配置（基于订阅级别）
# Free 用户
RATE_LIMIT_FREE_REQUESTS_PER_MINUTE=20
# Pro 用户
RATE_LIMIT_PRO_REQUESTS_PER_MINUTE=100
# Ultra 用户
RATE_LIMIT_ULTRA_REQUESTS_PER_MINUTE=300

# WebSocket 心跳间隔（秒）
WS_HEARTBEAT_INTERVAL=30

# 订单状态同步间隔（毫秒）
ORDER_SYNC_INTERVAL=60000
